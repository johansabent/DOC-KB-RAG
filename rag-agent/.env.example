# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

GOOGLE_API_KEY=YOUR_API_KEY_HERE
DB_CONNECTION_STRING=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DOCS_PATH=/path/to/your/docs/

# Model configuration
EMBED_MODEL=models/gemini-embedding-2-preview
LLM_MODEL=models/gemini-3.1-flash-lite-preview
EMBED_DIMENSIONS=3072

# Ingestion
COLLECTION_NAME=openclaw_docs
EMBED_BATCH_SIZE=100
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Query (SIMILARITY_TOP_K maps to hybrid_search_rrf match_count)
SIMILARITY_TOP_K=5

# Reranking (set SIMILARITY_TOP_K=20 when reranker is enabled)
RERANKER_ENABLED=false
RERANK_TOP_N=5
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
